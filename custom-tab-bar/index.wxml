<view class="tab-shell">
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-dot"></view>
      <text class="tab-text">{{item.text}}</text>
    </view>
  </view>
</view>