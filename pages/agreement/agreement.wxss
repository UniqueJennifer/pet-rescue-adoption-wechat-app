.policy-page {
  padding-bottom: 88rpx;
}

.policy-card {
  margin-top: 26rpx;
  padding: 26rpx;
  border: 3rpx solid #24342f;
  border-radius: 24rpx;
  background: #fffdf6;
  box-shadow: 6rpx 6rpx 0 rgba(36, 52, 47, 0.12);
}

.policy-title {
  display: block;
  color: #24342f;
  font-size: 31rpx;
  font-weight: 900;
}

.policy-text {
  display: block;
  margin-top: 14rpx;
  color: #466f4d;
  font-size: 26rpx;
  line-height: 1.6;
}
