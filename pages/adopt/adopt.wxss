.adopt-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.publish-mini {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 128rpx;
  min-height: 68rpx;
  border: 3rpx solid #24342f;
  border-radius: 18rpx;
  background: #087e72;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 5rpx 5rpx 0 rgba(36, 52, 47, 0.16);
}

.category-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 30rpx;
}

.category-card {
  position: relative;
  display: flex;
  overflow: hidden;
  min-height: 220rpx;
  border: 3rpx solid #24342f;
  border-radius: 28rpx;
  background: #fffdf6;
  box-shadow: 8rpx 8rpx 0 rgba(36, 52, 47, 0.15);
}

.cat-card {
  border-color: #ef705b;
  background: linear-gradient(135deg, #fff5f3, #fffdf6);
}

.cat-card .category-arrow {
  background: #ef705b;
  color: #ffffff;
}

.dog-card {
  border-color: #087e72;
  background: linear-gradient(135deg, #f0faf8, #fffdf6);
}

.dog-card .category-arrow {
  background: #087e72;
  color: #ffffff;
}

.category-img {
  flex: 0 0 280rpx;
  width: 280rpx;
  min-height: 220rpx;
  border-right: 3rpx solid #24342f;
}

.category-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 30rpx;
}

.category-title {
  display: block;
  color: #24342f;
  font-size: 48rpx;
  font-weight: 900;
}

.category-count {
  display: block;
  margin-top: 12rpx;
  color: #6f6a5d;
  font-size: 26rpx;
  font-weight: 700;
}

.category-arrow {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 900;
}

.back-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.back-btn {
  color: #087e72;
  font-size: 28rpx;
  font-weight: 800;
}

.current-category {
  color: #24342f;
  font-size: 32rpx;
  font-weight: 900;
}

.pet-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  margin-top: 28rpx;
}

.pet-card {
  overflow: hidden;
  border: 3rpx solid #24342f;
  border-radius: 24rpx;
  background: #fffdf6;
  box-shadow: 6rpx 6rpx 0 rgba(36, 52, 47, 0.13);
}

.pet-img {
  display: block;
  width: 100%;
  height: 250rpx;
  background: #eadfbf;
}

.pet-body {
  padding: 18rpx 18rpx 20rpx;
}

.pet-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  overflow: hidden;
}

.pet-name {
  overflow: hidden;
  color: #24342f;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 900;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.base-tag {
  flex: 0 0 auto;
  color: #ef705b;
  font-size: 20rpx;
  font-weight: 700;
}

.pet-meta {
  display: block;
  margin-top: 8rpx;
  color: #6f6a5d;
  font-size: 23rpx;
  text-align: center;
}