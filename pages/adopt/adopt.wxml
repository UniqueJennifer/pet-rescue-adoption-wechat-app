<view class="page">
  <view class="adopt-head">
    <view>
      <text class="page-title">猫狗领养</text>
      <text class="page-subtitle">浏览待领养的小猫小狗，也可以发布身边需要找家的动物信息。</text>
    </view>
    <button class="publish-mini" bindtap="goPublish">发布</button>
  </view>

  <view class="filters">
    <view class="filter {{activeType === '全部' ? 'active' : ''}}" data-type="全部" bindtap="changeType">全部</view>
    <view class="filter {{activeType === '猫咪' ? 'active' : ''}}" data-type="猫咪" bindtap="changeType">猫咪</view>
    <view class="filter {{activeType === '狗狗' ? 'active' : ''}}" data-type="狗狗" bindtap="changeType">狗狗</view>
  </view>

  <view class="pet-list" wx:if="{{pets.length}}">
    <view class="pet-card card" wx:for="{{pets}}" wx:key="id" data-id="{{item.id || item._id}}" bindtap="goDetail">
      <image class="pet-img" src="{{item.cover}}" mode="aspectFill"></image>
      <view class="pet-body">
        <text class="pet-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>当前分类暂无领养信息</view>
</view>
