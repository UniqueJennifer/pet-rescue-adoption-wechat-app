<view class="page login-page">
  <view class="login-hero">
    <text class="page-title">注册登录</text>
    <text class="page-subtitle">支持手机号登录，也可以使用微信头像昵称快速进入。</text>
  </view>

  <view class="mode-tabs">
    <view class="mode-tab {{mode === 'phone' ? 'active' : ''}}" data-mode="phone" bindtap="changeMode">手机号</view>
    <view class="mode-tab {{mode === 'wechat' ? 'active' : ''}}" data-mode="wechat" bindtap="changeMode">微信账号</view>
  </view>

  <view class="form-card section" wx:if="{{mode === 'phone'}}">
    <view class="field">
      <text class="label">昵称</text>
      <input class="input" placeholder-class="placeholder" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>
    <view class="field">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder-class="placeholder" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="agreement-row" bindtap="toggleAgreement">
      <text class="agreement-checkbox">{{agreed ? '✓' : ''}}</text>
      <text class="agreement-text">我已阅读并同意<text class="agreement-link" catchtap="openAgreement">《用户服务协议》</text>和<text class="agreement-link" catchtap="openPrivacy">《隐私政策》</text>，同意小程序按政策说明收集和使用手机号。</text>
    </view>
    <button class="primary-btn" bindtap="loginByPhone">登录 / 注册</button>
  </view>

  <view class="form-card section" wx:else>
    <button class="wechat-avatar" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatar}}" class="wechat-avatar-img" src="{{avatar}}" mode="aspectFill"></image>
      <text wx:else class="wechat-avatar-text">选择头像</text>
    </button>
    <view class="field">
      <text class="label">微信昵称</text>
      <input class="input" type="nickname" placeholder-class="placeholder" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>
    <view class="field">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder-class="placeholder" placeholder="可选，方便预约确认" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="agreement-row" bindtap="toggleAgreement">
      <text class="agreement-checkbox">{{agreed ? '✓' : ''}}</text>
      <text class="agreement-text">我已阅读并同意<text class="agreement-link" catchtap="openAgreement">《用户服务协议》</text>和<text class="agreement-link" catchtap="openPrivacy">《隐私政策》</text>，同意小程序按政策说明收集和使用账号信息及手机号。</text>
    </view>
    <button class="primary-btn" bindtap="loginByWechat">微信账号登录</button>
  </view>
</view>
