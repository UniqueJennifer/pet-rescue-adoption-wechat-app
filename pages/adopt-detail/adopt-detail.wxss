.detail-swiper {
  width: 100%;
  height: 520rpx;
  border: 3rpx solid #24342f;
  border-radius: 28rpx;
  background: #eadfbf;
  box-shadow: 6rpx 6rpx 0 rgba(36, 52, 47, 0.13);
  overflow: hidden;
}

.detail-image {
  width: 100%;
  height: 520rpx;
}

.detail-card {
  margin-top: 28rpx;
  padding: 26rpx;
  border: 3rpx solid #24342f;
  border-radius: 24rpx;
  background: #fffdf6;
  box-shadow: 6rpx 6rpx 0 rgba(36, 52, 47, 0.12);
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-head > view {
  min-width: 0;
}

.detail-name {
  display: block;
  color: #24342f;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 900;
}

.detail-meta,
.detail-owner {
  display: block;
  margin-top: 12rpx;
  color: #6f6a5d;
  font-size: 26rpx;
  line-height: 1.45;
}

.detail-owner {
  color: #087e72;
  font-weight: 800;
}

.detail-section-title {
  display: block;
  margin-bottom: 18rpx;
  color: #24342f;
  font-size: 32rpx;
  font-weight: 900;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 14rpx 0;
  border-top: 2rpx dashed #ded4b4;
}

.info-row:first-of-type {
  border-top: 0;
}

.info-label {
  flex: 0 0 128rpx;
  color: #6f6a5d;
  font-size: 25rpx;
  font-weight: 800;
}

.info-value {
  flex: 1;
  color: #24342f;
  font-size: 26rpx;
  line-height: 1.5;
}

.base-location-value,
.walk-status-value {
  color: #087e72;
  font-weight: 900;
}

.injury-value {
  color: #b44b3a;
  font-weight: 800;
}

.detail-intro {
  display: block;
  color: #466f4d;
  font-size: 28rpx;
  line-height: 1.65;
}

.contact-detail-btn {
  margin-top: 28rpx;
}
