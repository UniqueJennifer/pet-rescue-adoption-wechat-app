.profile-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  border: 3rpx solid #24342f;
  border-radius: 28rpx 28rpx 28rpx 58rpx;
  background: #fffdf6;
  box-shadow: 8rpx 8rpx 0 rgba(36, 52, 47, 0.14);
}

.avatar {
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: #eadfbf;
  border: 3rpx solid #24342f;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  overflow: hidden;
  color: #24342f;
  font-size: 34rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-phone {
  display: block;
  overflow: hidden;
  margin-top: 10rpx;
  color: #6f6a5d;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 116rpx;
  min-height: 64rpx;
  border: 3rpx solid #24342f;
  border-radius: 18rpx;
  background: #087e72;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}

.login-btn.ghost {
  background: #f6c453;
  color: #24342f;
}

.booking-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.booking-card,
.adoption-card {
  display: flex;
  min-height: 0;
  align-items: flex-start;
  overflow: hidden;
}

.card-image-wrap {
  position: relative;
  flex: 0 0 33.333%;
  width: 33.333%;
  aspect-ratio: 1 / 1;
  background: #eadfbf;
}

.booking-img,
.adoption-img {
  display: block;
  width: 100%;
  height: 100%;
}

.photo-count {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  padding: 5rpx 12rpx;
  border: 2rpx solid rgba(36, 52, 47, 0.8);
  border-radius: 999rpx;
  background: rgba(255, 253, 246, 0.9);
  color: #24342f;
  font-size: 19rpx;
  font-weight: 800;
  line-height: 1.2;
}

.booking-body,
.adoption-body {
  flex: 1;
  padding: 14rpx 16rpx;
  min-width: 0;
}

.booking-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.booking-top .pill {
  flex: 0 0 auto;
}

.booking-name {
  min-width: 0;
  color: #24342f;
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 800;
  white-space: normal;
  word-break: break-all;
}

.booking-time,
.booking-person {
  display: block;
  margin-top: 6rpx;
  color: #6f6a5d;
  font-size: 21rpx;
  line-height: 1.35;
  white-space: normal;
  word-break: break-all;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.adoption-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.delete-adoption-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  min-height: 46rpx;
  margin: 10rpx 0 0 auto;
  padding: 0 14rpx;
  border: 2rpx solid #c84f42;
  border-radius: 999rpx;
  background: #fff0eb;
  color: #b83f34;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 42rpx;
  box-shadow: 2rpx 2rpx 0 rgba(36, 52, 47, 0.1);
}

.delete-adoption-btn::after {
  border: 0;
}

.delete-adoption-btn:active {
  transform: translateY(2rpx);
  background: #ffe1d8;
  box-shadow: none;
}
