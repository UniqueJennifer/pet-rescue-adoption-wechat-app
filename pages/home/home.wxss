.home-page {
  padding-top: 24rpx;
}

.hero {
  min-height: 430rpx;
  padding: 36rpx;
  border: 4rpx solid #24342f;
  border-radius: 28rpx 28rpx 28rpx 80rpx;
  background:
    radial-gradient(circle at 88% 18%, rgba(246, 196, 83, 0.88) 0, rgba(246, 196, 83, 0.88) 54rpx, transparent 56rpx),
    radial-gradient(circle at 13% 86%, rgba(215, 235, 134, 0.9) 0, rgba(215, 235, 134, 0.9) 42rpx, transparent 44rpx),
    linear-gradient(135deg, rgba(8, 126, 114, 0.92), rgba(70, 111, 77, 0.86)), url("https://images.unsplash.com/photo-1450778869180-41d0601e046e?auto=format&fit=crop&w=1200&q=80");
  background-size: cover;
  background-position: center;
  color: #ffffff;
  box-shadow: 10rpx 10rpx 0 rgba(36, 52, 47, 0.18);
}

.hero-copy {
  max-width: 620rpx;
}

.eyebrow {
  display: block;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  display: block;
  margin-top: 28rpx;
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 800;
  letter-spacing: 0;
}

.hero-desc {
  display: block;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 27rpx;
  line-height: 1.55;
}

.hero-actions {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  gap: 20rpx;
  margin-top: 32rpx;
  width: 100%;
  max-width: 100%;
}

.hero-actions .hero-action-btn {
  flex: 1 1 0;
  width: auto;
  min-height: 78rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 3rpx solid #24342f;
  border-radius: 22rpx;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 72rpx;
  box-shadow: 6rpx 6rpx 0 rgba(36, 52, 47, 0.18);
}

.hero-actions .hero-action-btn::after {
  border: 0;
}

.hero-actions .primary-btn {
  background: #fffdf6;
  color: #087e72;
}

.hero-actions .secondary-btn {
  background: #f6c453;
  color: #24342f;
}

.hero-actions .hero-action-btn:active {
  transform: translateY(3rpx);
  box-shadow: 3rpx 3rpx 0 rgba(36, 52, 47, 0.16);
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 22rpx;
}

.stat-item {
  min-height: 130rpx;
  padding: 22rpx 12rpx;
  border: 3rpx solid #24342f;
  border-radius: 22rpx;
  background: #fffdf6;
  text-align: center;
  box-shadow: 6rpx 6rpx 0 rgba(36, 52, 47, 0.12);
}

.stat-num {
  display: block;
  color: #087e72;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 800;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #6f6a5d;
  font-size: 23rpx;
}

.home-page .section-head .section-action {
  display: inline-flex;
  flex: 0 0 auto;
  min-height: 58rpx;
  padding: 0 18rpx;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 3rpx solid #24342f;
  border-radius: 999rpx;
  background: #fff3a6;
  color: #24342f;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 4rpx 4rpx 0 rgba(36, 52, 47, 0.14);
}

.home-page .section-head .section-action-walk {
  background: #dff4ee;
  color: #087e72;
}

.section-action-arrow {
  font-size: 30rpx;
  line-height: 1;
}

.section-action-active {
  opacity: 0.82;
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 2rpx 2rpx 0 rgba(36, 52, 47, 0.12);
}

.pet-scroll {
  width: 100%;
  white-space: nowrap;
}

.pet-row {
  display: flex;
  gap: 20rpx;
}

.home-pet {
  flex: 0 0 292rpx;
  width: 292rpx;
  display: inline-block;
  margin-right: 20rpx;
  vertical-align: top;
}

.home-pet-img {
  display: block;
  width: 292rpx;
  height: 220rpx;
  background: #eadfbf;
}

.home-pet-body {
  padding: 20rpx;
  min-height: 156rpx;
}

.home-pet-line {
  display: block;
}

.home-pet-name {
  display: block;
  min-height: 72rpx;
  color: #24342f;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 800;
  white-space: normal;
  word-break: break-all;
}

.home-pet-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
}

.home-pet-tags .pill {
  flex: 0 0 auto;
}

.home-pet-info {
  display: block;
  overflow: hidden;
  margin-top: 10rpx;
  color: #6f6a5d;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.base-pill {
  background: #ef705b;
  color: #ffffff;
}

.walk-preview {
  display: flex;
  min-height: 190rpx;
  align-items: stretch;
}

.walk-swiper {
  width: 100%;
  height: 238rpx;
}

.walk-swiper swiper-item {
  padding: 4rpx 8rpx 28rpx;
  box-sizing: border-box;
}

.walk-swiper .walk-preview {
  height: 198rpx;
  min-height: 198rpx;
}

.walk-preview-img {
  width: 220rpx;
  min-height: 190rpx;
  background: #eadfbf;
}

.walk-preview-body {
  flex: 1;
  padding: 24rpx;
}

.walk-preview-title {
  display: block;
  color: #24342f;
  font-size: 32rpx;
  font-weight: 800;
}

.walk-preview-desc {
  display: block;
  margin-top: 14rpx;
  color: #6f6a5d;
  font-size: 25rpx;
  line-height: 1.5;
}
