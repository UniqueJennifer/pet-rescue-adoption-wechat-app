<view class="page">
  <text class="page-title">发布领养信息</text>
  <text class="page-subtitle">上传照片、填写基本情况和联系方式，方便有意向的领养人联系你。</text>

  <view class="form-card section">
    <view class="field">
      <text class="label">照片（最多9张，可选择原图）</text>
      <view class="photo-grid">
        <view class="photo-item" wx:for="{{form.images}}" wx:key="*this">
          <image class="photo-preview" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewImage"></image>
          <button class="photo-remove" data-index="{{index}}" bindtap="removeImage">×</button>
          <button class="photo-crop-btn" data-url="{{item}}" bindtap="cropCover">裁剪封面</button>
        </view>
        <view wx:if="{{form.images.length < 9}}" class="photo-picker" bindtap="chooseImage">
          <text class="photo-plus">+</text>
          <text class="photo-tip">添加照片</text>
        </view>
      </view>
      <view wx:if="{{form.cover}}" class="cover-crop-card">
        <text class="cover-crop-title">领养列表展示裁剪预览</text>
        <image class="cover-crop-preview" src="{{form.cover}}" mode="aspectFill" data-url="{{form.cover}}" bindtap="previewImage"></image>
        <text class="cover-crop-tip">点击照片上的“裁剪封面”可拖动选择想展示的部分；详情页仍保留原始照片。</text>
      </view>
    </view>

    <view class="field">
      <text class="label">名字</text>
      <input class="input" placeholder-class="placeholder" placeholder="例如 糯米" value="{{form.name}}" data-key="name" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">品种</text>
      <input class="input" placeholder-class="placeholder" placeholder="例如 中华田园猫 / 金毛 / 混血犬" value="{{form.breed}}" data-key="breed" bindinput="onInput" />
    </view>

    <view class="grid-two">
      <view class="field">
        <text class="label">类型</text>
        <picker range="{{typeOptions}}" value="{{typeIndex}}" bindchange="onTypeChange">
          <view class="picker-box">{{typeOptions[typeIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">公母</text>
        <picker range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
          <view class="picker-box">{{genderOptions[genderIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="field">
      <text class="label">年龄</text>
      <input class="input" placeholder-class="placeholder" placeholder="例如 8个月 / 2岁" value="{{form.age}}" data-key="age" bindinput="onInput" />
    </view>

    <view class="field">
      <text class="label">疾病历史</text>
      <textarea class="textarea short-textarea" placeholder-class="placeholder" placeholder="例如 无明显疾病史 / 曾有皮肤病，已治疗" value="{{form.diseaseHistory}}" data-key="diseaseHistory" bindinput="onInput" maxlength="180"></textarea>
    </view>

    <view class="grid-two">
      <view class="field">
        <text class="label">是否痊愈</text>
        <picker range="{{recoveredOptions}}" value="{{recoveredIndex}}" bindchange="onRecoveredChange">
          <view class="picker-box">{{recoveredOptions[recoveredIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">接种疫苗</text>
        <picker range="{{vaccinatedOptions}}" value="{{vaccinatedIndex}}" bindchange="onVaccinatedChange">
          <view class="picker-box">{{vaccinatedOptions[vaccinatedIndex]}}</view>
        </picker>
      </view>
    </view>

    <view class="field">
      <text class="label">情况简介</text>
      <textarea class="textarea" placeholder-class="placeholder" placeholder="说明性格、日常习惯、是否绝育、领养要求等" value="{{form.intro}}" data-key="intro" bindinput="onInput" maxlength="300"></textarea>
    </view>

    <view class="field">
      <text class="label">领养联系方式</text>
      <input class="input" type="text" placeholder-class="placeholder" placeholder="手机号、微信号、邮箱或其他联系方式" value="{{form.contact}}" data-key="contact" bindinput="onInput" />
    </view>

    <button class="primary-btn submit-btn" bindtap="submit">提交发布</button>
  </view>
</view>
